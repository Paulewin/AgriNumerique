@article{pedehourOutilsDaideDecision2023,
  title = {Outils d'aide \`a La D\'ecision Pour La R\'epartition de La Ressource En Eau En R\'egion {{Pays}} de La {{Loire}}},
  author = {Pedehour, Pauline},
  year = 2023,
  month = nov,
  journal = {LHB Hydroscience Journal},
  volume = {109},
  number = {1},
  pages = {8},
  publisher = {Taylor \& Francis Group},
  doi = {10.1080/27678490.2023.2271423},
  urldate = {2025-10-08},
  abstract = {This paper summarises the objectives, methods and results of my PHD thesis. In a context of limited availability of water with a plurality of decision-makers (public decision-makers, government, companies, households, etc.), this thesis offers decision-support tools to move towards optimal allocation of the water stock and better qualitative and quantitative use of the resource. Essential for domestic use, industry, irrigation and energy, water can also be a vector of externalities in terms of health, education, environment, and pollution. The availability of water in the Pays de la Loire region is constrained by a strong spatio-temporal heterogeneity, making it a complex and relevant area to study. It appears as a good reference example for many other regions. From a methodological point of view, the thesis uses theoretical and empirical economic approaches. Based on real data and the viewpoints of various water stakeholders it studies the levers of action for water on both the supply and the demand sides. Main results show that the expectations and priorities of the multitude of stakeholders involved for the resource vary widely. Results also suggest ways of reducing the sources of waste in the distribution networks and during water consumption. New solutions, such as non-monetary incentives, are considered to preserve and allocate the resource in an optimal way.},
  keywords = {Gouvernance de l'eau,networks,norme sociale,nudges,politiques publiques,public policies,reseaux,social norm,Water governance},
  file = {C:\Users\Winnie\Zotero\storage\8WZURYTY\Pedehour - 2023 - Outils d'aide à la décision pour la répartition de la ressource en eau en région Pays de la Loire.pdf}
}

